# =============================================================
# TecnoGems — .env.example
# نسخ هذا الملف إلى .env وتعبئة القيم الحقيقية
# cp .env.example .env
# =============================================================

# ----- أمان (مطلوب في الإنتاج) -----
# أنشئه بـ: python -c "import secrets; print(secrets.token_urlsafe(48))"
# V50.2 LOW: اترك هذا الحقل فارغاً حتى لا يُستخدم نص افتراضي بالخطأ في الإنتاج.
# التطبيق يرفض الإقلاع في الإنتاج إذا كانت القيمة فارغة أو هي النص الافتراضي.
SECRET_KEY=

# dev | production
FLASK_ENV=development

# ----- الموقع -----
BASE_URL=https://tecnogems.com

# ----- مدة الجلسة (بالأيام) — V50.2 خُفِّضت من 14 إلى 7 -----
SESSION_LIFETIME_DAYS=7

# ----- حساب الأدمن الافتراضي -----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<CHANGE-THIS-STRONG-PASSWORD>

# ----- البريد الإلكتروني (اختياري — للتحقق من الحساب واستعادة كلمة المرور) -----
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-email@gmail.com
# Gmail: استخدم App Password (16 حرف) وليس كلمة مرور الحساب
MAIL_PASSWORD=
MAIL_FROM=your-email@gmail.com

# ----- Google OAuth (اختياري) -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://tecnogems.com/auth/google/callback

# ----- Redis / RQ (اختياري — لـ background jobs دائمة) -----
# REDIS_URL=redis://localhost:6379/0
